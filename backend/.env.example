# Server Configurations
PORT=5000
NODE_ENV=development

# Database Connection (PostgreSQL connection string for Prisma)
DATABASE_URL="postgresql://username:password@localhost:5432/siddhivinayak_db?schema=public"

# JWT Secrets
JWT_SECRET="your_jwt_access_token_secret_here_make_it_long_and_secure"
JWT_REFRESH_SECRET="your_jwt_refresh_token_secret_here_make_it_long_and_secure"

# Cloudinary Storage Configurations
CLOUDINARY_CLOUD_NAME="your_cloudinary_cloud_name"
CLOUDINARY_API_KEY="your_cloudinary_api_key"
CLOUDINARY_API_SECRET="your_cloudinary_api_secret"
