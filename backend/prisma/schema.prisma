datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id                    String                 @id @default(uuid())
  phone                 String                 @unique
  name                  String?
  avatarUrl             String?
  isAdmin               Boolean                @default(false)
  role                  String                 @default("CUSTOMER") // CUSTOMER, DELIVERY, ADMIN
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt
  addresses             Address[]
  orders                Order[]                @relation("CustomerOrders")
  riderOrders           Order[]                @relation("RiderOrders")
  inventoryTransactions InventoryTransaction[]
  auditLogs             AuditLog[]
  devices               AdminDevice[]
  notifications         Notification[]

  @@map("users")
}

model Address {
  id             String   @id @default(uuid())
  userId         String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  recipientName  String
  recipientPhone String
  addressLine1   String
  addressLine2   String?
  landmark       String?
  city           String   @default("Panvel")
  state          String   @default("Maharashtra")
  postalCode     String
  isDefault      Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@map("addresses")
}

model Category {
  id            String         @id @default(uuid())
  name          String         @unique
  slug          String         @unique
  status        String         @default("ACTIVE")
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  subcategories Subcategory[]
  products      Product[]

  @@map("categories")
}

model Subcategory {
  id         String    @id @default(uuid())
  categoryId String
  category   Category  @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  name       String
  slug       String
  status     String    @default("ACTIVE")
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  products   Product[]

  @@unique([categoryId, name])
  @@map("subcategories")
}

model Brand {
  id        String    @id @default(uuid())
  name      String    @unique
  slug      String    @unique
  logoUrl   String?
  status    String    @default("ACTIVE")
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  products  Product[]

  @@map("brands")
}

model Product {
  id            String       @id @default(uuid())
  categoryId    String?
  category      Category?    @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  subcategoryId String?
  subcategory   Subcategory? @relation(fields: [subcategoryId], references: [id], onDelete: SetNull)
  brandId       String?
  brand         Brand?       @relation(fields: [brandId], references: [id], onDelete: SetNull)
  name          String
  slug          String       @unique
  description   String?
  sku           String?      @unique
  barcode       String?      @unique
  imageUrl      String?
  status        String       @default("ACTIVE")
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  variants      Variant[]
  orderItems    OrderItem[]

  @@map("products")
}

model Variant {
  id                    String                 @id @default(uuid())
  productId             String
  product               Product                @relation(fields: [productId], references: [id], onDelete: Cascade)
  attributeName         String                 // e.g. "Weight", "Volume"
  attributeValue        String                 // e.g. "1 Kg", "500 ml"
  price                 Decimal                @db.Decimal(10, 2)
  stock                 Int                    @default(0)
  status                String                 @default("ACTIVE")
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt
  inventoryTransactions InventoryTransaction[]
  orderItems            OrderItem[]

  @@map("variants")
}

model InventoryTransaction {
  id               String   @id @default(uuid())
  variantId        String
  variant          Variant  @relation(fields: [variantId], references: [id], onDelete: Cascade)
  quantity         Int      // Positive (addition) or negative (deduction)
  transactionType  String   // STOCK_ADDITION, STOCK_REDUCTION, MANUAL_ADJUSTMENT, ORDER_DEDUCTION, ORDER_RESTORE
  reason           String?
  adminUserId      String?
  adminUser        User?    @relation(fields: [adminUserId], references: [id], onDelete: SetNull)
  referenceOrderId String?
  referenceOrder   Order?   @relation(fields: [referenceOrderId], references: [id], onDelete: SetNull)
  createdAt        DateTime @default(now())

  @@map("inventory_transactions")
}

model Order {
  id                    String                 @id @default(uuid())
  orderNumber           String                 @unique
  userId                String?
  user                  User?                  @relation("CustomerOrders", fields: [userId], references: [id], onDelete: SetNull)
  status                String                 @default("PENDING") // PENDING, CONFIRMED, PROCESSING, PACKED, OUT_FOR_DELIVERY, DELIVERED, CANCELLED, REJECTED
  paymentMethod         String                 @default("COD") // COD, QR_PAYMENT
  totalAmount           Decimal                @db.Decimal(10, 2)
  deliveryCharge        Decimal                @default(0.00) @db.Decimal(10, 2)
  recipientName         String
  recipientPhone         String
  deliveryAddress       String
  deliveryRiderId       String?
  deliveryRider         User?                  @relation("RiderOrders", fields: [deliveryRiderId], references: [id], onDelete: SetNull)
  deliveryRiderName     String?
  deliveryRiderPhone    String?
  deliveryToken         String?
  deliveryTokenExpiresAt DateTime?
  deliveryOtp           String?
  deliveredAt           DateTime?
  cancelledAt           DateTime?
  cashCollected         Boolean                @default(false)
  cashCollectedAt       DateTime?
  codPaymentMode        String?
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt
  items                 OrderItem[]
  inventoryTransactions InventoryTransaction[]
  notifications         Notification[]

  @@map("orders")
}

model OrderItem {
  id          String   @id @default(uuid())
  orderId     String
  order       Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId   String?
  product     Product? @relation(fields: [productId], references: [id], onDelete: SetNull)
  variantId   String?
  variant     Variant? @relation(fields: [variantId], references: [id], onDelete: SetNull)
  productName String
  variantName String
  price       Decimal  @db.Decimal(10, 2)
  quantity    Int
  createdAt   DateTime @default(now())

  @@map("order_items")
}

model StoreSetting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt

  @@map("store_settings")
}

model AuditLog {
  id        String   @id @default(uuid())
  tableName String
  recordId  String
  action    String   // INSERT, UPDATE, DELETE
  oldValues Json?
  newValues Json?
  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  createdAt DateTime @default(now())

  @@map("audit_logs")
}

model AdminDevice {
  id         String   @id @default(uuid())
  adminId    String   @map("admin_id")
  admin      User     @relation(fields: [adminId], references: [id], onDelete: Cascade)
  fcmToken   String   @unique @map("fcm_token")
  browser    String?
  os         String?
  deviceType String?  @map("device_type")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  @@map("admin_devices")
}

model Notification {
  id        String   @id @default(uuid())
  title     String
  message   String
  type      String
  userId    String   @map("user_id")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  orderId   String?  @map("order_id")
  order     Order?   @relation(fields: [orderId], references: [id], onDelete: SetNull)
  isRead    Boolean  @default(false) @map("is_read")
  createdAt DateTime @default(now()) @map("created_at")

  @@map("notifications")
}
